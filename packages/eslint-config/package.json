{
  "name": "@linter-spec/eslint-config",
  "version": "1.0.2",
  "description": "Shareable ESLint 9 flat-config presets used by linter-spec (JS/TS x React/Vue/Node + essential softened variants).",
  "author": "SotherWind",
  "license": "MIT",
  "homepage": "https://github.com/SotherWind/linter-spec/tree/main/packages/eslint-config",
  "repository": {
    "type": "git",
    "url": "https://github.com/SotherWind/linter-spec.git",
    "directory": "packages/eslint-config"
  },
  "bugs": {
    "url": "https://github.com/SotherWind/linter-spec/issues"
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "flat-config",
    "linter-spec"
  ],
  "type": "module",
  "main": "./dist/configs/base.js",
  "types": "./dist/configs/base.d.ts",
  "exports": {
    ".": "./dist/configs/base.js",
    "./es5": "./dist/configs/es5.js",
    "./react": "./dist/configs/react.js",
    "./vue": "./dist/configs/vue.js",
    "./node": "./dist/configs/node.js",
    "./jsx-a11y": "./dist/configs/jsx-a11y.js",
    "./typescript": "./dist/configs/typescript/index.js",
    "./typescript/react": "./dist/configs/typescript/react.js",
    "./typescript/vue": "./dist/configs/typescript/vue.js",
    "./typescript/node": "./dist/configs/typescript/node.js",
    "./essential": "./dist/configs/essential/index.js",
    "./essential/es5": "./dist/configs/essential/es5.js",
    "./essential/react": "./dist/configs/essential/react.js",
    "./essential/vue": "./dist/configs/essential/vue.js",
    "./essential/typescript": "./dist/configs/essential/typescript/index.js",
    "./essential/typescript/react": "./dist/configs/essential/typescript/react.js",
    "./essential/typescript/vue": "./dist/configs/essential/typescript/vue.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "tsc -w",
    "test": "vitest run"
  },
  "dependencies": {
    "@eslint/js": "^9.12.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "eslint-plugin-import-x": "^4.3.1",
    "globals": "^15.10.0"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-n": "^17.10.3",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-vue": "^9.28.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.1",
    "vue-eslint-parser": "^9.4.3"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-jsx-a11y": {
      "optional": true
    },
    "eslint-plugin-n": {
      "optional": true
    },
    "eslint-plugin-react": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "eslint-plugin-vue": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "typescript-eslint": {
      "optional": true
    },
    "vue-eslint-parser": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "eslint": "^9.12.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-n": "^17.10.3",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-vue": "^9.28.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.1",
    "vitest": "^2.1.1",
    "vue-eslint-parser": "^9.4.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
