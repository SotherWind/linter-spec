{
  "name": "@linter-spec/stylelint-config",
  "version": "1.0.0",
  "description": "Shareable Stylelint config (CSS / SCSS / Less) used by linter-spec.",
  "author": "SotherWind",
  "license": "MIT",
  "homepage": "https://github.com/SotherWind/linter-spec/tree/main/packages/stylelint-config",
  "repository": {
    "type": "git",
    "url": "https://github.com/SotherWind/linter-spec.git",
    "directory": "packages/stylelint-config"
  },
  "bugs": {
    "url": "https://github.com/SotherWind/linter-spec/issues"
  },
  "keywords": [
    "stylelint",
    "stylelint-config",
    "scss",
    "less",
    "linter-spec"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "tsc -w",
    "test": "vitest run"
  },
  "dependencies": {
    "@stylistic/stylelint-plugin": "^5.2.0",
    "postcss-less": "^6.0.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-scss": "^7.2.0"
  },
  "peerDependencies": {
    "stylelint": "^17.0.0"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "stylelint": "^17.13.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
