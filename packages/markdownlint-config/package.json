  },
  "devDependencies": {
    "markdownlint": "^0.34.0",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
