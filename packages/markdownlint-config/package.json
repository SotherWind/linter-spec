{
  "name": "@linter-spec/markdownlint-config",
  "version": "1.0.0",
  "description": "Shareable markdownlint config used by linter-spec.",
  "author": "SotherWind",
  "license": "MIT",
  "homepage": "https://github.com/SotherWind/linter-spec/tree/main/packages/markdownlint-config",
  "repository": {
    "type": "git",
    "url": "https://github.com/SotherWind/linter-spec.git",
    "directory": "packages/markdownlint-config"
  },
  "bugs": {
    "url": "https://github.com/SotherWind/linter-spec/issues"
  },
  "keywords": [
    "markdownlint",
    "markdownlint-config",
    "linter-spec"
  ],
  "type": "module",
  "main": "./dist/index.js",
